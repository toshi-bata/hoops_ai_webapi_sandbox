# Copy this file to .env and fill in your values.

# HOOPS AI license key (required)
HOOPS_AI_LICENSE=your_license_key_here

# Path to the directory containing the HOOPS AI notebooks and output
# e.g. C:\hoops_ai\notebooks  or  /home/user/hoops_ai/notebooks
HOOPS_AI_NOTEBOOK_DIR=/path/to/notebooks

# MFR flow name (dataset produced by the ETL tutorial notebook)
# Output must exist at: <HOOPS_AI_NOTEBOOK_DIR>/out/flows/<HOOPS_AI_MFR_FLOW_NAME>/
HOOPS_AI_MFR_FLOW_NAME=ETL_CADSYNTH_training_b2
